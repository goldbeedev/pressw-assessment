# Anthropic API key, routed through LangChain's ChatAnthropic (never the
# anthropic SDK directly). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model id passed straight through to the Anthropic API.
ANTHROPIC_MODEL=claude-sonnet-5

# Tavily web search API key (free tier). Get one at https://tavily.com/
TAVILY_API_KEY=

# Comma-separated list of origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173
